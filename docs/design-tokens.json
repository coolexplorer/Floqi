{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "Floqi Design Tokens",
  "version": "1.0.0",
  "description": "Extracted from AI SaaS Dashboard UI Kit design references",
  "colors": {
    "slate": {
      "50": "#f8fafc",
      "100": "#f1f5f9",
